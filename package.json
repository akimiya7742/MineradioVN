{
  "name": "mineradio",
  "productName": "Mineradio",
  "version": "1.1.4",
  "description": "An immersive music player featuring a weather-themed radio, a lyric stage, particle visualizations, and a 3D playlist rack.",
  "author": "Mineradio",
  "main": "desktop/main.js",
  "private": true,
  "scripts": {
    "start": "cross-env NODE_ENV=development electron .",
    "server": "cross-env NODE_ENV=development node server.js",
    "action:build": "cross-env NODE_ENV=production electron-builder --win --linux",
    "build:win": "cross-env NODE_ENV=production electron-builder --win nsis",
    "build:win:dir": "cross-env NODE_ENV=production electron-builder --win dir",
    "build:linux": "cross-env NODE_ENV=production electron-builder --linux",
    "playwright:install": "cross-env PLAYWRIGHT_BROWSERS_PATH=resources/browsers npx playwright install chromium"
  },
  "build": {
    "appId": "com.mineradio.desktop",
    "productName": "Mineradio",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "linux": {
      "category": "Multimedia"
    },
    "afterPack": "build/after-pack.js",
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "files": [
      "desktop/**/*",
      "public/**/*",
      "build/**/*",
      "server.js",
      "dj-analyzer.js",
      "package.json",
      "!public/index.*.html",
      "public/index.html",
      "!node_modules/*",
      "!src/*"
    ],
    "extraResources": [
      {
        "from": "resources/browsers/",
        "to": "browsers/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": false,
    "win": {
      "executableName": "Mineradio",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mineradio",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "include": "build/installer.nsh",
      "artifactName": "Mineradio-${version}-Setup.${ext}"
    }
  },
  "mineradio": {
    "update": {
      "provider": "github",
      "owner": "akimiya7742",
      "repo": "MineradioVN",
      "preview": true,
      "preferMirrors": true,
      "mirrors": [
        "https://gh.llkk.cc/",
        "https://ghfast.top/",
        "https://gh-proxy.com/"
      ]
    }
  },
  "dependencies": {
    "axios": "^1.18.1",
    "cross-env": "^10.1.0",
    "electron-log": "^5.4.4",
    "gsap": "^3.15.0",
    "mpg123-decoder": "^1.0.3",
    "NeteaseCloudMusicApi": "^4.32.0",
    "playwright": "^1.61.1",
    "puppeteer-core": "^25.3.0",
    "user-agents": "^2.1.111",
    "youtubei.js": "^17.2.0"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "rcedit": "^5.0.2"
  }
}
